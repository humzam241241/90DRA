VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Note: OpenAI API key is stored as a Supabase secret (server-side only).
# Set it via: supabase secrets set OPENAI_API_KEY=sk-...
# Never expose API keys in VITE_ variables - they get bundled into the frontend.
