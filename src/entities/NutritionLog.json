{
  "name": "NutritionLog",
  "type": "object",
  "properties": {
    "date": {
      "type": "string",
      "format": "date",
      "description": "Date of the log"
    },
    "meal_type": {
      "type": "string",
      "enum": [
        "breakfast",
        "lunch",
        "dinner",
        "snack"
      ],
      "description": "Type of meal"
    },
    "meal_name": {
      "type": "string",
      "description": "Name of the meal"
    },
    "calories": {
      "type": "number",
      "description": "Total calories"
    },
    "protein": {
      "type": "number",
      "description": "Protein in grams"
    },
    "carbs": {
      "type": "number",
      "description": "Carbs in grams"
    },
    "fats": {
      "type": "number",
      "description": "Fats in grams"
    },
    "water_intake": {
      "type": "number",
      "description": "Water consumed in liters"
    },
    "notes": {
      "type": "string",
      "description": "Additional notes"
    }
  },
  "required": [
    "date",
    "meal_type"
  ]
}